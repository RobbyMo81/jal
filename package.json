{
  "name": "forgemp",
  "version": "1.0.0",
  "private": true,
  "description": "FORGE autonomous build loop",
  "main": "forge-memory-client.ts",
  "scripts": {
    "start": "bash ./forge.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "system:test": "npm run lint && npm run test && bash ./forge.sh 1",
    "config:build": "cd tools/config-gui && cargo build --release",
    "config": "cd tools/config-gui && cargo run"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0"
  }
}
