# Project Apex — Environment Configuration
# Copy to .env and fill in values. Never commit .env.

# ── Runtime Directories ───────────────────────────────────────────────────────
APEX_STATE_DIR=~/.apex/state
APEX_POLICY_DIR=~/.apex/policy
APEX_LOG_DIR=~/.apex/logs
APEX_OUTPUT_DIR=~/.apex/state/outputs

# ── Shell Execution ───────────────────────────────────────────────────────────
APEX_DEFAULT_SHELL=bash
APEX_COMMAND_TIMEOUT_SEC=900

# ── Heartbeat ─────────────────────────────────────────────────────────────────
# Interval in seconds. Configurable 60–1800 (1–30 min). Default: 300 (5 min).
APEX_HEARTBEAT_INTERVAL_SEC=300

# ── Workspace Policy ──────────────────────────────────────────────────────────
# Comma-separated list of absolute paths Apex may write to without Tier 2 approval.
APEX_WORKSPACE_ROOTS=~/projects

# ── Auth / Model Provider ─────────────────────────────────────────────────────
# Supported: ollama, jal-chain, guardian (Guardian Angle), stub (dev/test)
# Use 'jal-chain' for hardened local inference with gemma3 fallback.
APEX_DEFAULT_PROVIDER=jal-chain
APEX_DEFAULT_MODEL=qwen3:4b

# ── Ollama (First-Class Local Inference) ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── JAL Student Chain ─────────────────────────────────────────────────────────
# jal-chain: APEX_DEFAULT_MODEL (primary) → APEX_JAL_FALLBACK_MODEL (fallback)
APEX_JAL_FALLBACK_MODEL=gemma3:latest

# ── Guardian Angle (M_G supervises M_S via DVU Protocol) ─────────────────────
# Set to true to enable the Guardian/Student supervision pipeline.
APEX_GUARDIAN_ENABLED=false
# M_S student model — runs via jal-chain by default
APEX_GUARDIAN_STUDENT_MODEL=qwen3:4b
# M_G primary model — first link in guardian-chain (Claude → Gemini → OpenAI → local)
APEX_GUARDIAN_MODEL=claude-sonnet-4-6
# M_G local fallback (last resort when all cloud providers are unavailable)
APEX_GUARDIAN_FALLBACK_MODEL=gemma3:latest
# Entropy threshold [0-1] that triggers Guardian review. Default: 0.4
APEX_GUARDIAN_ENTROPY_THRESHOLD=0.4
# Domain accuracy threshold τ for Sleep Mode. Default: 0.92
APEX_GUARDIAN_SLEEP_THRESHOLD=0.92
# Sliding window size for domain accuracy tracking. Default: 20
APEX_GUARDIAN_SLEEP_WINDOW=20

# ── Cloud Provider API Keys ───────────────────────────────────────────────────
# Injected per-request into the guardian-chain. Leave blank to skip that link.
# Store real keys here only in local .env — never in .env.example or git.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Checkpoint / Recovery ─────────────────────────────────────────────────────
# Days to retain tool output files before cleanup. Default: 7.
APEX_OUTPUT_RETENTION_DAYS=7

# ── Memory ────────────────────────────────────────────────────────────────────
# Max storage for episodic memory per workspace (MB). Default: 50.
APEX_EPISODIC_MEMORY_QUOTA_MB=50
# Episodic memory TTL in days (from last access). Default: 30.
APEX_EPISODIC_MEMORY_TTL_DAYS=30

# ── Plugin Delivery (Phase 2 — disabled by default) ──────────────────────────
# APEX_PLUGIN_DELIVERY_MODE=polling
# APEX_PLUGIN_POLL_INTERVAL_SEC=10
