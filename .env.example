# Project Apex — Environment Configuration
# Copy to .env and fill in values. Never commit .env.

# ── Runtime Directories ───────────────────────────────────────────────────────
APEX_STATE_DIR=~/.apex/state
APEX_POLICY_DIR=~/.apex/policy
APEX_LOG_DIR=~/.apex/logs
APEX_OUTPUT_DIR=~/.apex/state/outputs

# ── Shell Execution ───────────────────────────────────────────────────────────
APEX_DEFAULT_SHELL=bash
APEX_COMMAND_TIMEOUT_SEC=900

# ── Heartbeat ─────────────────────────────────────────────────────────────────
# Interval in seconds. Configurable 60–1800 (1–30 min). Default: 300 (5 min).
APEX_HEARTBEAT_INTERVAL_SEC=300

# ── Workspace Policy ──────────────────────────────────────────────────────────
# Comma-separated list of absolute paths Apex may write to without Tier 2 approval.
APEX_WORKSPACE_ROOTS=~/projects

# ── Auth / Model Provider ─────────────────────────────────────────────────────
# Credentials are stored in OS keychain — never in this file.
# Set provider name only; auth flows via `apex auth login --provider <name>`.
APEX_DEFAULT_PROVIDER=

# ── Checkpoint / Recovery ─────────────────────────────────────────────────────
# Days to retain tool output files before cleanup. Default: 7.
APEX_OUTPUT_RETENTION_DAYS=7

# ── Memory ────────────────────────────────────────────────────────────────────
# Max storage for episodic memory per workspace (MB). Default: 50.
APEX_EPISODIC_MEMORY_QUOTA_MB=50
# Episodic memory TTL in days (from last access). Default: 30.
APEX_EPISODIC_MEMORY_TTL_DAYS=30

# ── Plugin Delivery (Phase 2 — disabled by default) ──────────────────────────
# APEX_PLUGIN_DELIVERY_MODE=polling
# APEX_PLUGIN_POLL_INTERVAL_SEC=10
